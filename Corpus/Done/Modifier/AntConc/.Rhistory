library(dplyr)
# Read the CSV files
marple_modifiers <- read.csv("S:/Studium/DH/Masterarbeit/Corpus/Done/Modifier/AntConc/A Murder is announced/Marple_Modifier.csv")
dfm_marple <- read.csv("S:/Studium/DH/Masterarbeit/Corpus/Done/Modifier/AntConc/A Murder is announced/Sentiment/dfm_Marple_neu.csv")
# Check if the number of rows are the same
if(nrow(marple_modifiers) != nrow(dfm_marple)) {
stop("The number of rows in the two CSV files do not match!")
}
# Combine the data
combined_data <- data.frame(
source = marple_modifiers$source,
negative = dfm_marple$negative,
positive = dfm_marple$positive,
neg_positive = dfm_marple$neg_positive,
neg_negative = dfm_marple$neg_negative
)
# Write the combined data to a new CSV file
write.csv(combined_data, "combined_data.csv", row.names = FALSE)
# Confirm completion
cat("CSV file 'combined_data.csv' has been created.")
# Write the combined data to a new CSV file
