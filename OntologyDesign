@prefix ac:   <http://example.org/agatha/> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .


ac:Person a rdfs:Class .
ac:Novel  a rdfs:Class .
ac:Method a rdfs:Class .   # Mordmethode
ac:Motive a rdfs:Class .   # Motiv
ac:Stabbing a ac:Method .
ac:Shooting a ac:Method .
ac:Strangling a ac:Method.
ac:Poisoning a ac:Method.
ac:FalseAlibi a ac:Method .
ac:Greed a ac:Motive .
ac:Revenge a ac:Motive.
ac:AvoidingBlackmail a ac:Motive .


ac:Murderer  rdfs:subClassOf ac:Person .   # Murderer is-a Person
ac:Victim    rdfs:subClassOf ac:Person .
ac:Detective rdfs:subClassOf ac:Person .
ac:Suspect   rdfs:subClassOf ac:Person.


# Object properties (entity -> entity) — the relational tissue
ac:hasMurderer  a rdf:Property ; rdfs:domain ac:Novel ;    rdfs:range ac:Murderer .
ac:hasVictim    a rdf:Property ; rdfs:domain ac:Novel ;    rdfs:range ac:Victim .
ac:hasDetective a rdf:Property ; rdfs:domain ac:Novel ;    rdfs:range ac:Detective .
ac:murdered     a rdf:Property ; rdfs:domain ac:Murderer ; rdfs:range ac:Victim .
ac:usedMethod   a rdf:Property ; rdfs:domain ac:Murderer ; rdfs:range ac:Method .
ac:hadMotive    a rdf:Property ; rdfs:domain ac:Murderer ; rdfs:range ac:Motive .

# Datatype properties (entity -> literal value)
ac:publicationYear a rdf:Property ; rdfs:domain ac:Novel ;  rdfs:range xsd:gYear .
ac:gender          a rdf:Property ; rdfs:domain ac:Person ; rdfs:range xsd:string .
ac:personName      a rdf:Property ; rdfs:domain ac:Person ; rdfs:range xsd:string .
ac:novelName       a rdf:Property;  rdfs:domain ac:Novel;   rdfs:range xsd:string.
ac:quotedSpeeches  a rdf:Property;  rdfs:domain ac:Person; rdfs:range xsd:integer.
ac:relationToVictim a rdf:Property; rdfs:domain ac:Person; rdfs:range xsd:string.



### The Murder of Roger Ackroyd (1926)
ac:RogerAckroyd a ac:Novel ;
    ac:novelName "The Murder of Roger Ackroyd" ;
    ac:publicationYear "1926"^^xsd:gYear ;
    ac:hasMurderer  ac:JamesSheppard ;
    ac:hasVictim    ac:RogerAckroydVictim ;
    ac:hasDetective ac:Poirot .
	
ac:Poirot a ac:Detective;
	ac:personName "Hercule Poirot";
	ac:gender "male".
	

ac:JamesSheppard a ac:Murderer ;
    ac:personName "Dr. James Sheppard" ;
    ac:gender "male" ;
    ac:murdered   ac:RogerAckroydVictim ;
    ac:usedMethod ac:Stabbing ;
    ac:hadMotive  ac:AvoidingBlackmail ;
	ac:quotedSpeeches 699.

ac:RogerAckroydVictim a ac:Victim ; ac:personName "Roger Ackroyd" ; ac:gender "male" .

ac:RalphPaton a ac:Suspect; ac:personName "Ralph Paton"; ac:gender "male"; ac:relationToVictim "Stepson".

### The A.B.C. Murders (1936)
ac:TheABCMurders a ac:Novel;
	ac:novelName "The A.B.C. Murders";
	ac:publicationYear "1936"^^xsd:gYear;
	ac:hasMurderer ac:FranklinClarke;
	ac:hasVictim ac:AliceAscher,ac:ElizabethBarnard, ac:SirCarmichaelClarke, ac:GeorgeEarlsfield. 
ac:Poirot a ac:Detective;
	ac:personName "Hercule Poirot";
	ac:gender "male".
ac:FranklinClarke a ac:Murderer;
	ac:personName "Franklin Clarke";
	ac:gender "male";
	ac:usedMethod ac:Shooting, ac:Strangling, ac:Stabbing;
	ac:hadMotive ac:Greed;
	ac:quotedSpeeches 229.
ac:AlexanderBonarpaCust a ac:Suspect;
	ac:personName "AlexanderBonarpaCust";
	ac:gender "male";
	ac:relationToVictim "none".

###And Then There were None (1939)
ac:AndThenThereWereNone a ac:Novel;
	ac:novelName "And Then There were None";
	ac:publicationYear "1939"^^xsd:gYear;
	ac:hasMurderer ac:JusticeWargrave;
	ac:hasVictim ac:VeraClaythorne, ac:PhilipLombard,ac:EmilyBrent,ac:GeneralMacarthur,ac:Rogers, ac:MrsRogers.
ac:JusticeWargrave a ac:Murderer;
	ac:personName "Justice Wargrave";
	ac:gender  "male";
	ac:usedMethod ac:Shooting,ac:Poisoning;
	ac:hadMotive ac:Revenge.
ac:DrArmstrong a ac:Suspect;
   ac:personName "Dr. Armstrong";
   ac:gender "male";
   ac:relationToVictim  "None".



### Death on the Nile (1937) 
ac:DeathOnTheNile a ac:Novel ;
    ac:novelName "Death on the Nile" ;
    ac:publicationYear "1937"^^xsd:gYear ;
    ac:hasMurderer  ac:PatrickRedfern	, ac:ChristineRedfern ;
    ac:hasVictim    ac:ArlenaMarschall ;
    ac:hasDetective ac:Poirot .

ac:ChristineRedfern  a ac:Murderer ;
    ac:personName "Christine Redfern" ;
    ac:gender "female" ;
    ac:usedMethod ac:FalseAlibi ;
    ac:hadMotive  ac:Greed;
	ac:quotedSpeeches 229.

ac:PatrickRedfern a ac:Murderer ;
    ac:personName "Patrick Redfern" ;
    ac:gender "male" ;
    ac:usedMethod ac:Shooting ;
    ac:hadMotive  ac:Greed;
	ac:quotedSpeeches 224.

ac:ArlenaMarschall a ac:Victim ; ac:personName "Arlena Marschall" ; ac:gender "female" .
ac:Poirot a ac:Detective;
	ac:personName "Hercule Poirot";
	ac:gender "male".
	
ac:KennethMarschall a ac:Suspect;
    ac:personName "Kenneth Marschall";
	ac:gender "male";
	ac:relationToVictim "Husband".
